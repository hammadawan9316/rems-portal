        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try {",
                  "  json = pm.response.json();",
                  "} catch (e) {}",
                  "",
                  "const directAccess = json.access_token || json.accessToken || null;",
                  "const directRefresh = json.refresh_token || json.refreshToken || null;",
                  "const dataAccess = json.data && (json.data.access_token || json.data.accessToken || (json.data.tokens && (json.data.tokens.access_token || json.data.tokens.accessToken)));",
                  "const dataRefresh = json.data && (json.data.refresh_token || json.data.refreshToken || (json.data.tokens && (json.data.tokens.refresh_token || json.data.tokens.refreshToken)));",
                  "",
                  "const accessToken = directAccess || dataAccess || '';",
                  "const refreshToken = directRefresh || dataRefresh || '';",
                  "",
                  "if (accessToken) {",
                  "  pm.collectionVariables.set('access_token', accessToken);",
                  "}",
                  "if (refreshToken) {",
                  "  pm.collectionVariables.set('refresh_token', refreshToken);",
                  "}",
                  "",
                  "pm.test('Login returned access token', function () {",
                  "  pm.expect(accessToken).to.not.eql('');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
